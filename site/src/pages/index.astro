---
import Manual from '../layouts/Manual.astro';
const base = import.meta.env.BASE_URL;

const chapters = [
  { slug: '01-installation', num: '01', title: '安裝與設定', desc: '系統需求、編譯安裝、加入輸入方式、匯入字表', icon: '⚙️' },
  { slug: '02-basic-typing', num: '02', title: '基本打字', desc: '組字、送字、選字、補碼、萬用碼、中英切換', icon: '⌨️' },
  { slug: '03-candidate-panel', num: '03', title: '選字窗', desc: '游標跟隨模式、固定位置模式、多螢幕、VoiceOver', icon: '🪟' },
  { slug: '04-modes-and-commands', num: '04', title: '模式與命令', desc: '繁簡切換、速打慢打、日文假名、,, 命令系統', icon: '🎛️' },
  { slug: '05-suggestion-engine', num: '05', title: '聯想引擎', desc: '三層架構、詞庫管理、用詞習慣、Emoji 聯想', icon: '🧠' },
  { slug: '06-lookup-modes', num: '06', title: '查碼模式', desc: '同音字查詢、注音反查、拼音查碼', icon: '🔍' },
  { slug: '07-shortcuts-and-extensions', num: '07', title: '快捷碼與擴充表', desc: '空碼綁定、擴充表格式、匯入匯出、iCloud 同步', icon: '⚡' },
  { slug: '08-preferences', num: '08', title: '偏好設定', desc: '設定程式五分頁完整說明', icon: '🎨' },
  { slug: '09-data-and-files', num: '09', title: '資料與檔案', desc: '資料路徑、語料架構、資料來源與授權', icon: '📁' },
  { slug: '10-faq', num: '10', title: '常見問題', desc: '疑難排解、已知限制', icon: '❓' },
  { slug: '11-domain-glossary', num: '11', title: '詞庫介紹', desc: '12 一般詞庫 + 28 專業詞典完整列表', icon: '📚' },
];

const keys = [
  { k: 'Space', d: '送字' },
  { k: '1–9', d: '選字' },
  { k: 'v r s f', d: '補碼 2–5' },
  { k: '* (Shift+8)', d: '萬用碼' },
  { k: 'vv + Space', d: '頓號' },
  { k: 'Enter', d: '送出原始碼' },
  { k: '快按 Shift', d: '中英切換' },
  { k: '按住 Shift', d: '暫時英文' },
  { k: 'Shift+Space', d: '全型空格' },
  { k: ',, + 碼 + Space', d: '命令模式' },
  { k: ',,ZH', d: '注音查碼' },
  { k: ',,PIN', d: '固定排序' },
];
---

<Manual title="首頁">
  <div class="not-prose">

    <!-- Hero -->
    <div class="pt-8 pb-14 sm:pt-12 sm:pb-20 anim-in">
      <div class="text-6xl sm:text-7xl mb-6">🦐</div>
      <h1 class="text-[36px] sm:text-[48px] font-bold tracking-tight leading-[1.1]
        text-ink-900 dark:text-ink-50">
        Yabomish<br/>
        <span class="text-mazu-cyan">使用手冊</span>
      </h1>
      <p class="mt-5 text-[17px] leading-relaxed max-w-lg
        text-ink-500 dark:text-ink-300">
        macOS 嘸蝦米輸入法 — 純 Swift、零依賴、離線聯想。<br/>
        11 章完整指南，從安裝到進階功能。
      </p>
      <div class="mt-8 flex items-center gap-4">
        <a href={`${base}chapters/01-installation/`}
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-[15px] font-semibold transition-all
             bg-mazu-orange text-white shadow-sm shadow-mazu-orange/20
             hover:bg-mazu-deep hover:shadow-md hover:shadow-mazu-orange/30
             dark:bg-mazu-gold dark:text-ink-900 dark:shadow-mazu-gold/10
             dark:hover:bg-mazu-gold/90">
          開始閱讀
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <span class="text-[12px] text-ink-400">v0.3.51</span>
      </div>
    </div>

    <!-- Chapter grid — 2 columns on desktop -->
    <section class="mb-16">
      <h2 class="text-[13px] font-bold uppercase tracking-[0.12em] mb-5
        text-mazu-deep/60 dark:text-mazu-gold/40">章節導覽</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {chapters.map(ch => (
          <a href={`${base}chapters/${ch.slug}/`}
             class="group flex items-start gap-3.5 p-4 rounded-2xl transition-all
               border border-paper-300/60 bg-white/30
               hover:border-mazu-cyan/30 hover:bg-mazu-cyan/[0.03] hover:shadow-sm
               dark:border-abyss-700/50 dark:bg-abyss-800/20
               dark:hover:border-mazu-cyan/20 dark:hover:bg-mazu-cyan/[0.03]">
            <div class="text-xl mt-0.5 opacity-60 group-hover:opacity-100 transition-opacity shrink-0">{ch.icon}</div>
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-0.5">
                <span class="font-mono text-[10.5px] text-ink-400">{ch.num}</span>
                <span class="text-[15px] font-semibold
                  text-ink-800 group-hover:text-mazu-cyan
                  dark:text-ink-100 dark:group-hover:text-mazu-cyan transition-colors">{ch.title}</span>
              </div>
              <p class="text-[13px] text-ink-400 dark:text-ink-400 leading-snug">{ch.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Quick reference — horizontal key cards -->
    <section>
      <h2 class="text-[13px] font-bold uppercase tracking-[0.12em] mb-5
        text-mazu-deep/60 dark:text-mazu-gold/40">⌨️ 快速參考</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
        {keys.map(item => (
          <div class="flex flex-col items-center justify-center py-3.5 px-3 rounded-xl text-center
            border border-paper-300/50 bg-white/20
            dark:border-abyss-700/40 dark:bg-abyss-800/20">
            <code class="text-[12px] font-semibold font-mono mb-1.5 px-2 py-0.5 rounded-md
              text-mazu-deep bg-mazu-orange/8 border border-mazu-orange/15
              dark:text-mazu-gold dark:bg-mazu-gold/10 dark:border-mazu-gold/15">{item.k}</code>
            <span class="text-[12px] text-ink-500 dark:text-ink-300">{item.d}</span>
          </div>
        ))}
      </div>
    </section>

  </div>
</Manual>
